    <link href="~/Content/bootstap-theme.css" rel="sytlesheet" />
    <link href="~/Content/ErrorStyles.css" rel="stylesheet" />
    <title></title>
</head>

<body>
    <div>
        @if (TempData["message"] != null)
            {
                <div class="alert alert-success">
                    @TempData["message"]
